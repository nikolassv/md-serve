<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            font-size: 16px;
            line-height: 1.6;
            color: #222;
            background: #fff;
            margin: 0;
            padding: 0 1rem 3rem;
        }

        .container {
            max-width: 860px;
            margin: 0 auto;
        }

        /* Breadcrumb */
        nav.breadcrumb {
            font-size: 0.875rem;
            color: #666;
            padding: 0.75rem 0;
            border-bottom: 1px solid #e5e5e5;
            margin-bottom: 1.5rem;
        }

        nav.breadcrumb a {
            color: #0969da;
            text-decoration: none;
        }

        nav.breadcrumb a:hover {
            text-decoration: underline;
        }

        nav.breadcrumb .sep {
            margin: 0 0.35em;
            color: #999;
        }

        nav.breadcrumb .current {
            color: #444;
        }

        /* Home link */
        nav.breadcrumb .home {
            color: #0969da;
            text-decoration: none;
        }

        nav.breadcrumb .home:hover {
            text-decoration: underline;
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            line-height: 1.25;
            margin-top: 1.5em;
            margin-bottom: 0.5em;
        }

        h1 { font-size: 2em; border-bottom: 1px solid #e5e5e5; padding-bottom: 0.3em; }
        h2 { font-size: 1.5em; border-bottom: 1px solid #e5e5e5; padding-bottom: 0.2em; }

        a { color: #0969da; }
        a:hover { text-decoration: underline; }

        /* Code */
        code {
            font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
            font-size: 0.875em;
            background: #f6f8fa;
            border: 1px solid #dde1e6;
            border-radius: 4px;
            padding: 0.1em 0.4em;
        }

        pre {
            background: #f6f8fa;
            border: 1px solid #dde1e6;
            border-radius: 6px;
            padding: 1rem;
            overflow-x: auto;
            line-height: 1.5;
        }

        pre code {
            background: none;
            border: none;
            padding: 0;
            font-size: 0.875em;
        }

        /* Blockquote */
        blockquote {
            margin: 0 0 1em;
            padding: 0 1em;
            color: #57606a;
            border-left: 4px solid #d0d7de;
        }

        /* Tables */
        table {
            border-collapse: collapse;
            width: 100%;
            margin-bottom: 1em;
        }

        th, td {
            border: 1px solid #d0d7de;
            padding: 0.4em 0.8em;
        }

        th { background: #f6f8fa; }

        /* File listing */
        ul.file-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        ul.file-list li {
            border-bottom: 1px solid #f0f0f0;
        }

        ul.file-list li:first-child {
            border-top: 1px solid #f0f0f0;
        }

        ul.file-list li a {
            display: block;
            padding: 0.5rem 0.25rem;
            color: #0969da;
            text-decoration: none;
        }

        ul.file-list li a:hover {
            background: #f6f8fa;
            text-decoration: none;
        }
    </style>
</head>
<body>
<div class="container">

    {{!-- Breadcrumb navigation --}}
    {{#if breadcrumbs}}
    <nav class="breadcrumb">
        <a class="home" href="/">Home</a>
        {{#each breadcrumbs}}
        <span class="sep">/</span>
        {{#if @last}}<span class="current">{{label}}</span>{{else}}<a href="{{path}}">{{label}}</a>{{/if}}
        {{/each}}
    </nav>
    {{/if}}

    <main>
        {{!-- File content (already rendered HTML) --}}
        {{#if content}}
        {{{content}}}
        {{/if}}

        {{!-- Directory listing --}}
        {{#if files}}
        <h1>{{title}}</h1>
        <ul class="file-list">
            {{#each files}}
            <li><a href="{{path}}">{{name}}</a></li>
            {{/each}}
        </ul>
        {{/if}}
    </main>

</div>
{{!--
    Front matter values from YAML front matter are available as {{frontmatter.key}}.
    Example: {{frontmatter.author}}, {{frontmatter.date}}
--}}
</body>
</html>

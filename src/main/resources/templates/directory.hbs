<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="generator" content="md-serve (https://github.com/nikolassv/md-serve)">
    <title>{{title}}</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            font-size: 16px;
            line-height: 1.6;
            color: #222;
            background: #fff;
            margin: 0;
            padding: 0 1rem 3rem;
        }

        .container {
            max-width: 860px;
            margin: 0 auto;
        }

        nav.breadcrumb {
            font-size: 0.875rem;
            color: #666;
            padding: 0.75rem 0;
            border-bottom: 1px solid #e5e5e5;
            margin-bottom: 1.5rem;
        }

        nav.breadcrumb a { color: #0969da; text-decoration: none; }
        nav.breadcrumb a:hover { text-decoration: underline; }
        nav.breadcrumb .sep { margin: 0 0.35em; color: #999; }
        nav.breadcrumb .current { color: #444; }
        nav.breadcrumb .home { color: #0969da; text-decoration: none; }
        nav.breadcrumb .home:hover { text-decoration: underline; }

        h1 { font-size: 2em; border-bottom: 1px solid #e5e5e5; padding-bottom: 0.3em; line-height: 1.25; margin-top: 1.5em; margin-bottom: 0.5em; }

        a { color: #0969da; }
        a:hover { text-decoration: underline; }

        ul.file-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        ul.file-list li { border-bottom: 1px solid #f0f0f0; }
        ul.file-list li:first-child { border-top: 1px solid #f0f0f0; }

        ul.file-list li a {
            display: block;
            padding: 0.5rem 0.25rem;
            color: #0969da;
            text-decoration: none;
        }

        ul.file-list li a:hover { background: #f6f8fa; text-decoration: none; }

        .layout { display: flex; gap: 2rem; align-items: flex-start; }

        nav.site-tree {
            flex: 0 0 200px;
            font-size: 0.875rem;
            border-right: 1px solid #e5e5e5;
            padding-right: 1.5rem;
            padding-top: 0.5rem;
        }

        nav.site-tree .tree-list { list-style: none; margin: 0; padding: 0; }
        nav.site-tree .tree-list .tree-list { padding-left: 1em; }
        nav.site-tree li { margin: 0.15em 0; }
        nav.site-tree a { color: #444; text-decoration: none; display: inline-block; padding: 0.1em 0.3em; border-radius: 3px; }
        nav.site-tree a:hover { background: #f6f8fa; color: #0969da; }
        nav.site-tree a.active, nav.site-tree li.active > details > summary > a { font-weight: 600; color: #0969da; }
        nav.site-tree details > summary { list-style: none; cursor: pointer; }
        nav.site-tree details > summary::-webkit-details-marker { display: none; }
        nav.site-tree details > summary::before { content: "▶ "; font-size: 0.65em; vertical-align: middle; color: #999; }
        nav.site-tree details[open] > summary::before { content: "▼ "; }

        .main-content { flex: 1; min-width: 0; }
    </style>
</head>
<body>
<div class="container">

    <nav class="breadcrumb">
        <a class="home" href="/">Home</a>
        {{#each breadcrumbs}}
        <span class="sep">/</span>
        {{#if @last}}<span class="current">{{label}}</span>{{else}}<a href="{{path}}">{{label}}</a>{{/if}}
        {{/each}}
    </nav>

    <div class="layout">

        {{#if tree}}
        <nav class="site-tree">
            {{{treeNav tree}}}
        </nav>
        {{/if}}

        <main class="main-content">
            <h1>{{title}}</h1>
            {{#if files}}
            <ul class="file-list">
                {{#each files}}
                <li><a href="{{path}}">{{name}}</a></li>
                {{/each}}
            </ul>
            {{/if}}
        </main>

    </div>

</div>
</body>
</html>
